{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node tools/vite-no-links.mjs",
    "edge:app": "powershell -ExecutionPolicy Bypass -File tools/open-edge-debug.ps1 http://127.0.0.1:3000/",
    "app:edge": "powershell -ExecutionPolicy Bypass -File tools/open-edge-debug.ps1 \"http://127.0.0.1:3000/?battle-layout-editor=1\"",
    "edge:editor": "powershell -ExecutionPolicy Bypass -File tools/open-edge-debug.ps1 \"http://127.0.0.1:3000/?battle-layout-editor=1\"",
    "edge:debug": "powershell -ExecutionPolicy Bypass -File tools/open-edge-debug.ps1 \"http://127.0.0.1:3000/?battle-layout-preview=1&battle-layout-debug=1\"",
    "relay": "tsx server/relayServer.ts",
    "test": "node --import tsx --test src/data/content.test.ts src/data/contentSelectors.test.ts src/data/contentInsights.test.ts src/data/contentEditor.test.ts src/logic/gameLogic.test.ts src/components/screens/battleResolution.test.ts src/components/screens/BattleSceneSpace.test.ts src/components/screens/BattleDebugContracts.test.ts src/components/screens/battleVisualPlan.test.ts src/components/screens/battleSimplePlayGeometry.test.ts src/components/screens/battleSimplePlayStep.test.ts src/components/screens/battleSimplePlayRuntime.test.ts src/components/screens/battleCompositeSchedule.test.ts src/components/screens/battlePreviewPlayback.test.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nanoid": "^5.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
